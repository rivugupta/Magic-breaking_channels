Notebook[{

Cell[CellGroupData[{
Cell["Unitary", "Chapter",
 CellChangeTimes->{{3.915234369106408*^9, 
  3.915234392922476*^9}},ExpressionUUID->"dc4cdb5d-9c09-4a7f-a57d-\
bb5c6c6c856d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"U2", "=", 
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", 
          FractionBox[
           RowBox[{
            RowBox[{"2", "\[Pi]"}], "-", 
            RowBox[{"(", 
             RowBox[{"\[Phi]", "+", "\[Psi]"}], ")"}]}], "2"]}]]}], 
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          FractionBox[
           RowBox[{"(", 
            RowBox[{"\[Phi]", "-", "\[Psi]"}], ")"}], "2"]}]]}]},
      {
       RowBox[{"\[ImaginaryI]", " ", 
        RowBox[{"Sin", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"\[ImaginaryI]", " ", 
          FractionBox[
           RowBox[{"(", 
            RowBox[{"\[Phi]", "-", "\[Psi]"}], ")"}], "2"]}]]}], 
       RowBox[{
        RowBox[{"Cos", "[", 
         RowBox[{"\[Theta]", "/", "2"}], "]"}], 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", "\[ImaginaryI]"}], " ", 
          FractionBox[
           RowBox[{
            RowBox[{"2", "\[Pi]"}], "-", 
            RowBox[{"(", 
             RowBox[{"\[Phi]", "+", "\[Psi]"}], ")"}]}], "2"]}]]}]}
     },
     GridBoxDividers->{"Columns" -> {{True}}, "Rows" -> {{True}}}], 
    "\[NoBreak]", ")"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9147496667179213`*^9, 3.914749686533145*^9}, {
   3.9147500408980217`*^9, 3.914750108890308*^9}, 3.914750215133885*^9, {
   3.9147509301563883`*^9, 3.9147509368392277`*^9}, {3.9147509735630913`*^9, 
   3.914750978345018*^9}, {3.914751255721239*^9, 3.9147512872454157`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"1d40d0d2-e8f3-4333-a9f8-7390d7a26062"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Initial state and final state", "Chapter",
 CellChangeTimes->{{3.915234399113624*^9, 
  3.91523440928531*^9}},ExpressionUUID->"53a192e3-0382-4264-b629-\
7cb8dd1fba72"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Rho]i", "[", 
   RowBox[{"m1_", ",", "m2_", ",", "m3_"}], "]"}], ":=", 
  RowBox[{"Evaluate", "[", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], "*", 
     RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "+", 
    RowBox[{
     FractionBox["1", "2"], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"m1", "*", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "+", 
       RowBox[{"m2", "*", 
        RowBox[{"PauliMatrix", "[", "2", "]"}]}], "+", 
       RowBox[{"m3", "*", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ")"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]fc", "[", 
   RowBox[{
   "t1_", ",", "t2_", ",", "t3_", ",", "m1_", ",", "m2_", ",", "m3_", ",", 
    "\[Lambda]1_", ",", "\[Lambda]2_", ",", "\[Lambda]3_"}], "]"}], ":=", 
  RowBox[{"Evaluate", "[", 
   RowBox[{
    RowBox[{
     FractionBox["1", "2"], "*", 
     RowBox[{"IdentityMatrix", "[", "2", "]"}]}], "+", 
    RowBox[{
     FractionBox["1", "2"], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"t1", "+", 
          RowBox[{"m1", "*", "\[Lambda]1"}]}], ")"}], "*", 
        RowBox[{"PauliMatrix", "[", "1", "]"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"t2", "+", 
          RowBox[{"m2", "*", "\[Lambda]2"}]}], ")"}], "*", 
        RowBox[{"PauliMatrix", "[", "2", "]"}]}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"t3", "+", 
          RowBox[{"m3", "*", "\[Lambda]3"}]}], ")"}], "*", 
        RowBox[{"PauliMatrix", "[", "3", "]"}]}]}], ")"}]}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]f", "[", 
   RowBox[{
   "t1_", ",", "t2_", ",", "t3_", ",", "m1_", ",", "m2_", ",", "m3_", ",", 
    "\[Lambda]1_", ",", "\[Lambda]2_", ",", "\[Lambda]3_", ",", "\[Theta]_", 
    ",", "\[Phi]_", ",", "\[Psi]_"}], "]"}], ":=", 
  RowBox[{"Evaluate", "[", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{"U2", ".", 
      RowBox[{"\[Rho]fc", "[", 
       RowBox[{
       "t1", ",", "t2", ",", "t3", ",", "m1", ",", "m2", ",", "m3", ",", 
        "\[Lambda]1", ",", "\[Lambda]2", ",", "\[Lambda]3"}], "]"}], ".", 
      RowBox[{"ConjugateTranspose", "[", "U2", "]"}]}], ",", 
     RowBox[{"Element", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", "\[Phi]", ",", "\[Psi]"}], "}"}], ",", 
       "Reals"}], "]"}]}], "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9147502284520607`*^9, 3.91475028604348*^9}, {
  3.914750335446766*^9, 3.914750376099636*^9}, {3.914751612212214*^9, 
  3.9147518014504128`*^9}, {3.914836369566308*^9, 3.9148363720910263`*^9}, {
  3.914836447203745*^9, 3.9148365269258833`*^9}, {3.9148375527634277`*^9, 
  3.914837570662506*^9}, {3.9148385036938257`*^9, 3.914838610679081*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"26852345-3adf-4280-91ca-36e2f26b704b"]
}, Open  ]],

